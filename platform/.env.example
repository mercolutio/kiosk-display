# --- Datenbank ---
# Vercel injiziert POSTGRES_URL automatisch, sobald du im Projekt einen
# Postgres-Store verbindest (Storage-Tab). Lokal die Connection-URL eintragen.
POSTGRES_URL=

# --- Admin-Login (Weboberflaeche) ---
# Passwort fuer den Login in die Verwaltungsoberflaeche.
ADMIN_PASSWORD=bitte-aendern
# Langer Zufallsstring zum Signieren der Session-Cookies (z.B. `openssl rand -hex 32`).
SESSION_SECRET=bitte-langen-zufallsstring-setzen
