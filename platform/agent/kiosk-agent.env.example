# Kopieren nach ~/.config/kiosk-agent.env und ausfuellen.
KIOSK_API_URL=https://dein-projekt.vercel.app
KIOSK_DEVICE_TOKEN=hier-das-geraete-token-aus-der-plattform
KIOSK_SITES_PATH=/home/denizschloesser/kiosk-display/sites.json
KIOSK_RESTART_CMD=systemctl --user restart kiosk
KIOSK_POLL_SECONDS=15
KIOSK_OUTPUT=HDMI-A-1
