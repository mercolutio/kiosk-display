[Unit]
Description=Kiosk Display (Electron)
After=graphical-session.target
PartOf=graphical-session.target
# Sicherheitsnetz gegen Neustart-Schleifen: nach 10 Fehlstarts in 120s aufgeben,
# statt endlos zu hammern. Wiederbeleben dann mit:
#   systemctl --user reset-failed kiosk && systemctl --user start kiosk
StartLimitIntervalSec=120
StartLimitBurst=10

[Service]
Type=simple
Environment=WAYLAND_DISPLAY=wayland-0
WorkingDirectory=%h/kiosk-display
ExecStart=%h/kiosk-display/node_modules/.bin/electron . --fullscreen --ozone-platform=wayland --disable-gpu
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
